{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "projectSettings": {
    "framework": "nextjs"
  },
  "regions": ["gru1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
