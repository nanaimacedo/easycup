# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin Login (obrigatório)
# Gere o hash com: node -e "require('bcryptjs').hash('SUA_SENHA', 12).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...

# CSRF Secret (obrigatório - gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CSRF_SECRET=

# 2FA (opcional - gere via GET /api/auth/2fa e escaneie no Google Authenticator)
# ADMIN_TOTP_SECRET=
